---
const sections = ["home", "about", "experience", "technologies", "projects", "contact"];
---

<div class="fixed right-4 md:right-6 bottom-5 md:top-1/2 md:-translate-y-1/2 md:bottom-auto z-40 flex flex-col gap-2">
  <button
    id="nav-up"
    class="group inline-flex h-9 w-9 items-center justify-center rounded-md border border-[color:var(--terminal-border-strong)] bg-[color:var(--terminal-surface)]/80 text-[color:var(--terminal-green)] backdrop-blur-md transition-all hover:border-[color:var(--terminal-green-dim)] hover:bg-[color:var(--terminal-green-faint)] disabled:cursor-not-allowed disabled:opacity-30"
    aria-label="Ir a la sección anterior"
  >
    <i class="hn hn-angle-up text-lg"></i>
  </button>
  <button
    id="nav-down"
    class="group inline-flex h-9 w-9 items-center justify-center rounded-md border border-[color:var(--terminal-border-strong)] bg-[color:var(--terminal-surface)]/80 text-[color:var(--terminal-green)] backdrop-blur-md transition-all hover:border-[color:var(--terminal-green-dim)] hover:bg-[color:var(--terminal-green-faint)] disabled:cursor-not-allowed disabled:opacity-30"
    aria-label="Ir a la siguiente sección"
  >
    <i class="hn hn-angle-down text-lg"></i>
  </button>
</div>

<script is:inline define:vars={{ sections }}>
  let currentIndex = 0;
  const navUp = document.getElementById("nav-up");
  const navDown = document.getElementById("nav-down");

  function go(i) {
    if (i < 0 || i >= sections.length) return;
    const id = sections[i];
    if (id === "home") {
      window.scrollTo({ top: 0, behavior: "smooth" });
    } else {
      const el = document.getElementById(id);
      if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
    }
    currentIndex = i;
    updateButtons();
  }

  function updateButtons() {
    if (!navUp || !navDown) return;
    navUp.disabled = currentIndex === 0;
    navDown.disabled = currentIndex === sections.length - 1;
  }

  function detect() {
    if (window.scrollY < 120) {
      currentIndex = 0;
      updateButtons();
      return;
    }
    const center = window.scrollY + window.innerHeight / 2;
    let closest = 0;
    let min = Infinity;
    sections.forEach((id, i) => {
      if (id === "home") return;
      const el = document.getElementById(id);
      if (!el) return;
      const rect = el.getBoundingClientRect();
      const mid = window.scrollY + rect.top + rect.height / 2;
      const d = Math.abs(mid - center);
      if (d < min) {
        min = d;
        closest = i;
      }
    });
    currentIndex = closest;
    updateButtons();
  }

  navUp && navUp.addEventListener("click", () => go(currentIndex - 1));
  navDown && navDown.addEventListener("click", () => go(currentIndex + 1));

  let t;
  window.addEventListener("scroll", () => {
    clearTimeout(t);
    t = setTimeout(detect, 80);
  });
  detect();
</script>
