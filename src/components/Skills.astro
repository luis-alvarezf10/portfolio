---
import Icons from "./Icons.astro";
import { skillColors, skillsData } from "../constants/skills";

const categories = [
  { id: "lenguajes", label: "languages", flag: "--lang" },
  { id: "frontend",  label: "frontend",  flag: "--fe"   },
  { id: "backend",   label: "backend",   flag: "--be"   },
  { id: "databases", label: "databases", flag: "--db"   },
];
---

<div class="w-[92%] md:w-[88%] lg:w-[72%] mx-auto">
  <!-- Header -->
  <header class="mb-6 flex items-end justify-between flex-wrap gap-4">
    <div>
      <p class="text-xs text-[color:var(--terminal-muted)] prompt-line">npm list --depth=0</p>
      <h2 class="font-sans text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mt-1 text-balance">
        <span class="text-[color:var(--terminal-comment)]">{"//"}</span> skills
      </h2>
    </div>
  </header>

  <!-- Tabs as terminal flags -->
  <div class="relative inline-flex flex-wrap gap-1 rounded-md border border-[color:var(--terminal-border-strong)] bg-[color:var(--terminal-surface)]/80 p-1 w-full md:w-auto">
    <div id="pill-bg" class="pointer-events-none absolute inset-y-1 left-1 rounded-sm bg-[color:var(--terminal-green-faint)] border border-[color:var(--terminal-green-dim)] transition-all duration-300 ease-out"></div>
    {
      categories.map((cat, i) => (
        <button
          class={`skill-btn relative z-10 inline-flex items-center gap-2 rounded-sm px-3 py-1.5 text-sm font-medium transition-colors ${i === 0 ? "is-active" : ""}`}
          data-category={cat.id}
        >
          <span class="text-[color:var(--terminal-comment)]">{cat.flag}</span>
          <span>{cat.label}</span>
        </button>
      ))
    }
  </div>

  <!-- List -->
  <div class="mt-6 tw-window">
    <div class="tw-titlebar">
      <span class="tw-dot tw-dot-red"></span>
      <span class="tw-dot tw-dot-yellow"></span>
      <span class="tw-dot tw-dot-green"></span>
      <span class="flex-1 text-center text-[color:var(--terminal-muted)]">
        <span class="text-[color:var(--terminal-comment)]">—</span>
        <span>zsh</span>
        <span class="text-[color:var(--terminal-comment)]"> — </span>
        <span id="category-label">languages</span>
      </span>
    </div>

    <div class="p-5 md:p-6">
      <div class="text-xs text-[color:var(--terminal-muted)] mb-4 prompt-line">
        npm list <span id="flag-label" class="text-[color:var(--terminal-green)]">--lang</span>
      </div>
      <p class="text-xs text-[color:var(--terminal-comment)] mb-3">
        <span class="text-[color:var(--terminal-green)]">luis@portfolio</span>:<span class="text-[color:var(--terminal-green)]">~</span>$ <span id="category-count"></span>
      </p>

      <div id="skills-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">
        {
          Object.entries(skillsData).map(([category, skills]) =>
            skills.map((skill) => {
              const isDefault = category === "lenguajes";
              const customColor = skillColors[skill.name as keyof typeof skillColors];
              return (
                <div
                  class={`skill-item group flex items-center gap-2 rounded-md border border-[color:var(--terminal-border)] bg-black/20 px-3 py-2 transition-all duration-300 ${isDefault ? "opacity-100 scale-100" : "hidden opacity-0 scale-95"}`}
                  data-category={category}
                >
                  <span class="text-[color:var(--terminal-comment)] text-xs">├─</span>
                  <Icons
                    name={skill.icon}
                    class={`h-4 w-4 shrink-0 fill-current text-[color:var(--terminal-muted)] transition-colors group-hover:text-[color:var(--terminal-green)] ${customColor || ""}`}
                  />
                  <span class="text-sm font-medium text-[color:var(--terminal-text)] truncate">{skill.name}</span>
                </div>
              );
            })
          )
        }
      </div>

      <div class="mt-4 flex items-center gap-2 text-[color:var(--terminal-green)]">
        <span class="font-bold select-none">$</span>
        <span class="blink font-bold">_</span>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  const buttons = document.querySelectorAll(".skill-btn");
  const skillItems = document.querySelectorAll(".skill-item");
  const pill = document.getElementById("pill-bg");
  const labelEl = document.getElementById("category-label");
  const flagEl = document.getElementById("flag-label");
  const countEl = document.getElementById("category-count");

  const updatePill = () => {
    const active = document.querySelector(".skill-btn.is-active");
    if (pill && active) {
      pill.style.width = active.offsetWidth + "px";
      pill.style.height = active.offsetHeight + "px";
      pill.style.left = active.offsetLeft + "px";
      pill.style.top = active.offsetTop + "px";
    }
  };

  const updateCount = (cat) => {
    let n = 0;
    skillItems.forEach((el) => {
      if (el.getAttribute("data-category") === cat) n++;
    });
    if (countEl) countEl.innerHTML = '<span class="text-[color:var(--terminal-muted)]">found ' + n + ' packages</span>';
  };

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const cat = button.getAttribute("data-category");
      buttons.forEach((b) => b.classList.remove("is-active"));
      button.classList.add("is-active");
      updatePill();

      if (labelEl) labelEl.textContent = button.querySelector("span:nth-child(2)").textContent;
      if (flagEl)  flagEl.textContent = button.querySelector("span:first-child").textContent;
      updateCount(cat);

      skillItems.forEach((el) => {
        if (el.getAttribute("data-category") === cat) {
          el.classList.remove("hidden");
          requestAnimationFrame(() => {
            el.classList.add("opacity-100", "scale-100");
            el.classList.remove("opacity-0", "scale-95");
          });
        } else {
          el.classList.add("opacity-0", "scale-95");
          el.classList.remove("opacity-100", "scale-100");
          setTimeout(() => {
            if (el.classList.contains("opacity-0")) el.classList.add("hidden");
          }, 240);
        }
      });
    });
  });

  window.addEventListener("load", () => { updatePill(); updateCount("lenguajes"); });
  window.addEventListener("resize", updatePill);
</script>

<style>
  .skill-btn {
    color: var(--terminal-muted);
    background: transparent;
  }
  .skill-btn:hover { color: var(--terminal-text); }
  .skill-btn.is-active { color: var(--terminal-green); }
  .skill-btn.is-active span:first-child { color: var(--terminal-green); }
</style>
