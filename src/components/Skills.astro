---
import Icons from "./Icons.astro";
import { skillColors, skillsData } from "../constants/skills";

const categories = [
  { id: "lenguajes", label: "Lenguajes" },
  { id: "frontend", label: "Frontend" },
  { id: "backend", label: "Backend" },
  { id: "databases", label: "Bases de Datos" },
];
---

<section class="flex flex-col items-center justify-center py-10">
  <h2 class="w-[80%] lg:w-[60%] font-bold text-4xl mb-6">Skills</h2>
  <div class="w-[80%] lg:w-[60%] flex flex-col gap-6">
    
    <div class="relative inline-flex flex-wrap justify-center gap-2 p-1 bg-white/5 border border-white/10 rounded-xl w-full mx-auto overflow-hidden">
      <div id="pill-bg" class="absolute bg-[#07f9a2] rounded-lg transition-all duration-300 ease-out z-0"></div>
      {categories.map((cat, index) => (
        <button
          class={`skill-btn px-4 py-2.5 text-sm sm:text-base font-medium rounded-xl transition-all duration-200 w-full sm:w-auto cursor-pointer z-10 ${index === 0 ? "active" : ""}`}
          data-category={cat.id}
        >
          <span class="flex items-center justify-center gap-2">{cat.label}</span>
        </button>
      ))}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 cursor-default" id="skills-grid">
      {Object.entries(skillsData).map(([category, skills]) =>
        skills.map((skill) => {
          const isDefault = category === "lenguajes";
          const customColor = skillColors[skill.name as keyof typeof skillColors];
          return (
            <div
              class={`skill-item group bg-white/5 border border-white/10 p-4 rounded-xl flex flex-col items-center gap-3 transition-all duration-500 ${isDefault ? "flex opacity-100 scale-100" : "hidden opacity-0 scale-90"}`}
              data-category={category}
            >
              <Icons
                name={skill.icon}
                class={`w-8 h-8 text-gray-400 fill-current transition-colors duration-300 ${customColor || "group-hover:text-[#07f9a2]"}`}
              />
              <span class="font-semibold text-sm group-hover:font-bold transition-all duration-300">{skill.name}</span>
            </div>
          );
        })
      )}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll(".skill-btn");
  const skillItems = document.querySelectorAll(".skill-item");
  const pill = document.getElementById("pill-bg");

  const updatePill = () => {
    const activeBtn = document.querySelector(".skill-btn.active") as HTMLElement;
    if (pill && activeBtn) {
      pill.style.width = `${activeBtn.offsetWidth}px`;
      pill.style.height = `${activeBtn.offsetHeight}px`;
      pill.style.left = `${activeBtn.offsetLeft}px`;
      pill.style.top = `${activeBtn.offsetTop}px`;
    }
  };

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const category = button.getAttribute("data-category");

      // 1. Update Buttons
      buttons.forEach((btn) => btn.classList.remove("active"));
      button.classList.add("active");
      updatePill();

      // 2. Filter with Transition
      skillItems.forEach((item) => {
        const el = item as HTMLElement;
        if (el.dataset.category === category) {
          el.classList.remove("hidden");
          // Pequeño timeout para que el navegador note el cambio de 'hidden' antes de la opacidad
          setTimeout(() => {
            el.classList.add("flex", "opacity-100", "scale-100");
            el.classList.remove("opacity-0", "scale-90");
          }, 10);
        } else {
          el.classList.add("opacity-0", "scale-90");
          el.classList.remove("opacity-100", "scale-100");
          // Esperamos a que termine la animación para ocultar
          setTimeout(() => {
            if (el.classList.contains("opacity-0")) {
              el.classList.add("hidden");
              el.classList.remove("flex");
            }
          }, 300);
        }
      });
    });
  });

  window.addEventListener("load", updatePill);
  window.addEventListener("resize", updatePill);
</script>

<style>
  /* Tus estilos originales preservados */
  .skill-btn { color: #9ca3af; }
  .skill-btn.active { color: #030b13; font-weight: 600; }
  .skill-btn:hover:not(.active) { color: white; }

  .skill-item {
    position: relative;
    overflow: hidden;
    color: inherit;
    /* Quitamos el transform fijo de aquí para que no choque con la animación de entrada */
  }

  .skill-item:hover { transform: translateY(-5px) scale(1.05) !important; }

  .skill-item::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(209, 213, 219, 0.5) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
    pointer-events: none;
  }

  .skill-item:hover::before {
    opacity: 0.2;
    background: linear-gradient(135deg, currentColor 0%, transparent 100%);
  }

  .skill-item > * { position: relative; z-index: 1; }
</style>