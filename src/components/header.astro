---
import logo from "../assets/LA.svg";

const links: { name: string; href: string; cmd: string }[] = [
  { name: "home",         href: "#home",         cmd: "~" },
  { name: "about",        href: "#about",        cmd: "~/about" },
  { name: "experience",   href: "#experience",   cmd: "~/exp" },
  { name: "stack",        href: "#technologies", cmd: "~/stack" },
  { name: "projects",     href: "#projects",     cmd: "~/projects" },
];
---

<header
  class="sticky top-3 z-50 mx-auto flex h-14 w-[92%] md:w-[88%] lg:w-[72%] items-center justify-between rounded-lg border border-[color:var(--terminal-border-strong)] bg-[color:var(--terminal-surface)]/85 px-3 md:px-4 backdrop-blur-xl shadow-[0_8px_32px_-12px_rgba(0,0,0,0.6)]"
>
  <!-- Logo / path -->
  <a href="#home" class="flex items-center gap-2 text-sm">
    <img src={logo.src} alt="Logo Luis Álvarez" width="22" height="22" />
    <span class="hidden sm:flex items-center gap-1 text-[color:var(--terminal-muted)]">
      <span class="text-[color:var(--terminal-green)]">luis</span>
      <span class="text-[color:var(--terminal-comment)]">@</span>
      <span>portfolio</span>
      <span class="text-[color:var(--terminal-comment)]">:</span>
      <span id="active-path" class="text-[color:var(--terminal-green)]">~</span>
      <span class="text-[color:var(--terminal-comment)]">$</span>
    </span>
  </a>

  <!-- Desktop nav -->
  <nav class="hidden md:block" aria-label="Navegación principal">
    <ul class="flex items-center gap-1 text-sm">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            data-section={link.href.substring(1)}
            data-cmd={link.cmd}
            class="nav-link group inline-flex items-center gap-1 rounded-md px-2.5 py-1.5 text-[color:var(--terminal-muted)] transition-colors hover:text-[color:var(--terminal-green)]"
          >
            <span class="text-[color:var(--terminal-comment)] group-hover:text-[color:var(--terminal-green)]">./</span>
            <span>{link.name}</span>
          </a>
        </li>
      ))}
      <li>
        <a
          href="#contact"
          class="ml-1 inline-flex items-center gap-2 rounded-md border border-[color:var(--terminal-green-dim)] bg-[color:var(--terminal-green-faint)] px-3 py-1.5 text-sm font-semibold text-[color:var(--terminal-green)] transition-all hover:bg-[color:var(--terminal-green)] hover:text-[#030b13]"
        >
          <span>./contact</span>
          <span class="blink">_</span>
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile menu button -->
  <button
    id="menu-btn"
    class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded-md border border-[color:var(--terminal-green-dim)] bg-[color:var(--terminal-green-faint)] text-[color:var(--terminal-green)]"
    aria-label="Abrir menú"
  >
    <i class="hn hn-bars-solid"></i>
  </button>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-menu"
  class="fixed right-0 top-0 z-[60] h-screen w-72 translate-x-full border-l border-[color:var(--terminal-border-strong)] bg-[color:var(--terminal-surface)]/95 p-6 backdrop-blur-xl transition-transform duration-300 ease-in-out md:hidden"
>
  <div class="flex items-center justify-between border-b border-[color:var(--terminal-border)] pb-3">
    <span class="text-xs text-[color:var(--terminal-muted)]">~/menu</span>
    <button id="close-btn" class="text-[color:var(--terminal-green)]" aria-label="Cerrar menú">
      <i class="hn hn-times-solid text-xl"></i>
    </button>
  </div>

  <ul class="mt-6 flex flex-col gap-2 text-sm">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="flex items-center gap-2 rounded-md px-2 py-2 text-[color:var(--terminal-muted)] hover:bg-[color:var(--terminal-green-faint)] hover:text-[color:var(--terminal-green)]"
        >
          <span class="text-[color:var(--terminal-comment)]">$</span>
          <span>cd {link.cmd}</span>
        </a>
      </li>
    ))}
    <li class="mt-2">
      <a
        href="#contact"
        class="flex items-center justify-between rounded-md border border-[color:var(--terminal-green-dim)] bg-[color:var(--terminal-green-faint)] px-3 py-2 font-semibold text-[color:var(--terminal-green)]"
      >
        <span>./contact</span>
        <span class="blink">_</span>
      </a>
    </li>
  </ul>
</div>

<script is:inline>
  const menuBtn = document.getElementById("menu-btn");
  const closeBtn = document.getElementById("close-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const activePathEl = document.getElementById("active-path");

  const openMenu = () => mobileMenu && mobileMenu.classList.remove("translate-x-full");
  const closeMenu = () => mobileMenu && mobileMenu.classList.add("translate-x-full");

  if (menuBtn) menuBtn.addEventListener("click", openMenu);
  if (closeBtn) closeBtn.addEventListener("click", closeMenu);

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (e) => {
      const targetId = anchor.getAttribute("href");
      if (!targetId) return;
      e.preventDefault();
      if (targetId === "#" || targetId === "#home") {
        window.scrollTo({ top: 0, behavior: "smooth" });
      } else {
        const el = document.querySelector(targetId);
        if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
      }
      closeMenu();
    });
  });

  // Active section highlighting
  function setActive() {
    const sections = Array.from(document.querySelectorAll("section[id], main[id]"));
    if (sections.length === 0) return;

    let activeId = "home";
    if (window.scrollY < 120) {
      activeId = "home";
    } else {
      const center = window.scrollY + window.innerHeight / 2;
      let minDist = Infinity;
      sections.forEach((s) => {
        const rect = s.getBoundingClientRect();
        const mid = window.scrollY + rect.top + rect.height / 2;
        const d = Math.abs(mid - center);
        if (d < minDist) {
          minDist = d;
          activeId = s.id;
        }
      });
    }

    document.querySelectorAll(".nav-link").forEach((link) => {
      const section = link.getAttribute("data-section");
      if (section === activeId) {
        link.classList.add("is-active");
      } else {
        link.classList.remove("is-active");
      }
    });

    if (activePathEl) {
      const activeLink = document.querySelector('.nav-link[data-section="' + activeId + '"]');
      if (activeLink) {
        activePathEl.textContent = activeLink.getAttribute("data-cmd") || "~";
      }
    }
  }

  let ticking = false;
  window.addEventListener("scroll", () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        setActive();
        ticking = false;
      });
      ticking = true;
    }
  });
  document.addEventListener("DOMContentLoaded", setActive);
  setActive();
</script>

<style>
  .nav-link.is-active {
    color: var(--terminal-green);
    background-color: var(--terminal-green-faint);
  }
  .nav-link.is-active span:first-child {
    color: var(--terminal-green);
  }
</style>
