---
import { socialLinks } from "../constants/socialLinks";

const contactChannels = [
  { name: "GitHub",   href: "https://github.com/luis-alvarezf10",              icon: "hn hn-github",           handle: "@luis-alvarezf10" },
  { name: "LinkedIn", href: "https://www.linkedin.com/in/luis-%C3%A1lvarez-franceschi-a2080b225/", icon: "hn hn-linkedin",  handle: "luis-álvarez-franceschi" },
  { name: "WhatsApp", href: "https://wa.link/p8zz2b",                          icon: "hn hn-phone-ringing-low", handle: "+58 · dm open" },
  { name: "X",        href: "https://x.com/luis_alvarezf10",                   icon: "hn hn-x",                handle: "@luis_alvarezf10" },
];
---

<section
  id="contact"
  class="relative min-h-[90dvh] flex flex-col justify-center py-20 md:py-28"
>
  <div class="w-[92%] md:w-[88%] lg:w-[72%] mx-auto">
    <!-- Header -->
    <header class="mb-8 flex items-end justify-between flex-wrap gap-4">
      <div>
        <p class="text-xs text-[color:var(--terminal-muted)] prompt-line">./send-message --to=luis</p>
        <h2 class="font-sans text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mt-1 text-balance">
          <span class="text-[color:var(--terminal-comment)]">{"//"}</span> let&apos;s connect
        </h2>
      </div>
      <span class="hidden md:inline text-xs text-[color:var(--terminal-comment)]">
        [ secure channel · end-to-end ]
      </span>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-5">
      <!-- Contact channels -->
      <div class="tw-window">
        <div class="tw-titlebar">
          <span class="tw-dot tw-dot-red"></span>
          <span class="tw-dot tw-dot-yellow"></span>
          <span class="tw-dot tw-dot-green"></span>
          <span class="flex-1 text-center text-[color:var(--terminal-muted)]">
            <span class="text-[color:var(--terminal-comment)]">—</span>
            <span>channels.sh</span>
          </span>
        </div>
        <div class="p-5 md:p-6">
          <p class="text-xs text-[color:var(--terminal-muted)] mb-3 prompt-line">cat channels.sh</p>
          <p class="text-sm text-[color:var(--terminal-muted)] leading-relaxed mb-5">
            <span class="text-[color:var(--terminal-comment)]"># </span>
            ¿Tienes una idea o proyecto? Escríbeme por cualquier canal o envíame el mensaje directamente desde la derecha.
          </p>

          <ul class="space-y-2">
            {
              contactChannels.map((c) => (
                <li>
                  <a
                    href={c.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-3 rounded-md border border-[color:var(--terminal-border)] bg-black/20 px-3 py-2.5 transition-all hover:border-[color:var(--terminal-green-dim)] hover:bg-[color:var(--terminal-green-faint)] group"
                  >
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-sm border border-[color:var(--terminal-border-strong)] bg-[color:var(--terminal-bg)] text-[color:var(--terminal-green)]">
                      <i class={c.icon}></i>
                    </span>
                    <span class="flex-1 min-w-0">
                      <span class="block text-sm font-semibold text-[color:var(--terminal-text)]">{c.name}</span>
                      <span class="block text-xs text-[color:var(--terminal-muted)] truncate">{c.handle}</span>
                    </span>
                    <span class="text-[color:var(--terminal-comment)] group-hover:text-[color:var(--terminal-green)] transition-colors">→</span>
                  </a>
                </li>
              ))
            }
          </ul>

          <div class="mt-5 text-[11px] text-[color:var(--terminal-comment)] flex items-center gap-2">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[color:var(--terminal-green)] shadow-[0_0_8px_rgba(7,249,162,0.8)]"></span>
            <span>online &amp; listening</span>
            <span>·</span>
            <span>usual response: &lt; 24h</span>
          </div>
        </div>
      </div>

      <!-- Terminal form -->
      <div class="tw-window">
        <div class="tw-titlebar">
          <span class="tw-dot tw-dot-red"></span>
          <span class="tw-dot tw-dot-yellow"></span>
          <span class="tw-dot tw-dot-green"></span>
          <span class="flex-1 text-center text-[color:var(--terminal-muted)]">
            <span class="text-[color:var(--terminal-comment)]">—</span>
            <span>send-message.sh</span>
          </span>
        </div>

        <form id="contact-form" class="p-5 md:p-6 space-y-4">
          <p class="text-xs text-[color:var(--terminal-muted)] prompt-line">./send-message.sh --interactive</p>
          <p class="text-xs text-[color:var(--terminal-comment)]"># completa cada campo para compilar el mensaje</p>

          <!-- Name -->
          <div class="space-y-1">
            <label class="flex items-center gap-2 text-xs text-[color:var(--terminal-muted)]">
              <span class="text-[color:var(--terminal-green)]">&gt;</span>
              <span>name:</span>
            </label>
            <input
              type="text"
              name="user_name"
              placeholder="nombre o razón social"
              required
              class="cli-input w-full"
              autocomplete="name"
            />
          </div>

          <!-- Email + Phone -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="space-y-1">
              <label class="flex items-center gap-2 text-xs text-[color:var(--terminal-muted)]">
                <span class="text-[color:var(--terminal-green)]">&gt;</span>
                <span>email:</span>
              </label>
              <input
                type="email"
                name="user_email"
                placeholder="you@domain.com"
                required
                class="cli-input w-full"
                autocomplete="email"
              />
            </div>
            <div class="space-y-1">
              <label class="flex items-center gap-2 text-xs text-[color:var(--terminal-muted)]">
                <span class="text-[color:var(--terminal-green)]">&gt;</span>
                <span>phone:</span>
                <span class="text-[color:var(--terminal-comment)]">(opcional)</span>
              </label>
              <input
                type="tel"
                name="user_phone"
                placeholder="+58 412 ..."
                class="cli-input w-full"
                autocomplete="tel"
              />
            </div>
          </div>

          <!-- Message -->
          <div class="space-y-1">
            <label class="flex items-center gap-2 text-xs text-[color:var(--terminal-muted)]">
              <span class="text-[color:var(--terminal-green)]">&gt;</span>
              <span>message:</span>
            </label>
            <textarea
              name="message"
              placeholder="escribe tu mensaje aquí..."
              required
              rows="5"
              class="cli-input w-full resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <div class="flex items-center justify-between gap-3 pt-2">
            <p id="status-msg" class="text-xs text-[color:var(--terminal-comment)]">
              <span class="text-[color:var(--terminal-green)]">$</span>
              ready to execute
              <span class="blink">_</span>
            </p>
            <button type="submit" class="cmd-btn cmd-btn-primary">
              <span id="btn-label">./execute</span>
              <i class="hn hn-paper-plane-solid"></i>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import emailjs from "@emailjs/browser";

  const contactForm = document.getElementById("contact-form") as HTMLFormElement | null;
  const btnLabel = document.getElementById("btn-label");
  const statusMsg = document.getElementById("status-msg");

  if (contactForm) {
    contactForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const serviceID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
      const templateID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
      const publicKey = import.meta.env.PUBLIC_EMAILJS_KEY;

      if (btnLabel) btnLabel.textContent = "./sending...";
      if (statusMsg) statusMsg.innerHTML = '<span class="text-[color:var(--terminal-yellow)]">$ compiling message...</span>';

      try {
        await emailjs.sendForm(serviceID, templateID, contactForm, publicKey);
        if (statusMsg) statusMsg.innerHTML = '<span class="text-[color:var(--terminal-green)]">$ [OK] message delivered</span>';
        contactForm.reset();
      } catch (err) {
        console.error("Error:", err);
        if (statusMsg) statusMsg.innerHTML = '<span class="text-[color:var(--terminal-red)]">$ [ERR] failed — try again</span>';
      } finally {
        if (btnLabel) btnLabel.textContent = "./execute";
      }
    });
  }
</script>

<style>
  .cli-input {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--terminal-border);
    color: var(--terminal-text);
    border-radius: 6px;
    padding: 0.6rem 0.75rem;
    font-family: inherit;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    caret-color: var(--terminal-green);
  }
  .cli-input::placeholder {
    color: var(--terminal-comment);
  }
  .cli-input:focus {
    border-color: var(--terminal-green-dim);
    background: rgba(7, 249, 162, 0.04);
    box-shadow: 0 0 0 2px rgba(7, 249, 162, 0.15);
  }
</style>
