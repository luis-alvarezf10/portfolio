---
import SocialMedia from "../components/SocialMedia.astro";
import GlobeWireframe from '@/components/ui/globe-wireframe';
import Footer from "../components/footer.astro";

---
<section id="contact" class="relative min-h-[100dvh] flex flex-col items-center justify-center pt-12">
  <div class="absolute inset-0 z-0 pointer-events-none">
    <GlobeWireframe 
      client:load 
      className="w-full h-full opacity-10" 
      enableInteraction={false}
      rotationSpeed={15000}
      strokeColor="#07f9a2"        
  sphereOutlineColor="#07f9a2"   
  graticuleColor="#07f9a2"       
  graticuleOpacity={0.15}
  autoRotateSpeed={0.05}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#05050a] via-transparent to-transparent"></div>
  </div>
  <div class="bento-container mx-auto w-[90%] md:w-[80%] lg:w-full z-10 py-5">
    <form id="contact-form" class="parent relative overflow-hidden py-5">
      
      <div class="div1 card bento-card group rounded-xl relative overflow-hidden p-6 border border-white/10 bg-[#0a0a0a]">
        <div class="pointer-events-none absolute -inset-px opacity-0 group-hover:opacity-100 transition duration-500 z-10"
          style="background: radial-gradient(600px circle at var(--mouse-x, 0px) var(--mouse-y, 0px), rgba(7, 249, 162, 0.15), transparent 40%);">
        </div>
        <div class="relative z-20">
          <h2 class="text-2xl font-bold text-white mb-4">¿Tienes alguna idea o proyecto en mente?</h2>
          <SocialMedia />
        </div>
      </div>

      <div class="div2 card bento-card group rounded-xl relative overflow-hidden p-6 border border-white/10 bg-[#0a0a0a]">
        <div class="pointer-events-none absolute -inset-px opacity-0 group-hover:opacity-100 transition duration-500 z-10"
          style="background: radial-gradient(600px circle at var(--mouse-x, 0px) var(--mouse-y, 0px), rgba(7, 249, 162, 0.15), transparent 40%);">
        </div>
        <div class="relative z-20 h-full flex flex-col">
          <h3 class="text-lg font-semibold text-white mb-4">Información</h3>
          <div class="flex flex-col gap-3">
            <input
              type="text"
              name="user_name"
              placeholder="Nombre o Razón Social"
              class="w-full p-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-gray-500 focus:border-[#07f9a2]/50 focus:ring-1 focus:ring-[#07f9a2]/50 outline-none transition"
              required
            />
            <input
              type="email"
              name="user_email"
              placeholder="Email"
              class="w-full p-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-gray-500 focus:border-[#07f9a2]/50 focus:ring-1 focus:ring-[#07f9a2]/50 outline-none transition"
              required
            />
            <input
              type="tel"
              name="user_phone"
              placeholder="Teléfono"
              class="w-full p-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-gray-500 focus:border-[#07f9a2]/50 focus:ring-1 focus:ring-[#07f9a2]/50 outline-none transition"
            />
          </div>
        </div>
      </div>

      <div class="div3 card bento-card group rounded-xl relative overflow-hidden p-6 border border-white/10 bg-[#0a0a0a]">
        <div class="pointer-events-none absolute -inset-px opacity-0 group-hover:opacity-100 transition duration-500 z-10"
          style="background: radial-gradient(600px circle at var(--mouse-x, 0px) var(--mouse-y, 0px), rgba(7, 249, 162, 0.15), transparent 40%);">
        </div>
        <div class="relative z-20 h-full flex flex-col">
          <h3 class="text-lg font-semibold text-white mb-4">Mensaje</h3>
          <textarea
            name="message"
            placeholder="Escribe tu mensaje aquí..."
            class="w-full flex-grow p-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-gray-500 focus:border-[#07f9a2]/50 focus:ring-1 focus:ring-[#07f9a2]/50 outline-none transition min-h-[120px] resize-none"
            required></textarea>
        </div>
      </div>

      <div class="div4 card bento-card group rounded-xl relative overflow-hidden border border-white/10 bg-[#0a0a0a]">
        <div class="pointer-events-none absolute -inset-px opacity-0 group-hover:opacity-100 transition duration-500 z-10"
          style="background: radial-gradient(800px circle at var(--mouse-x, 0px) var(--mouse-y, 0px), rgba(7, 249, 162, 0.2), transparent 40%);">
        </div>
        <button type="submit" class="button w-full relative z-20">Enviar</button>
      </div>
    </form>
  </div>
  <Footer />
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".bento-card");

  cards.forEach((card) => {
    card.addEventListener("mousemove", (e) => {
      const rect = card.getBoundingClientRect();
      
      // Calculamos la posición del mouse relativa ÚNICAMENTE a esta tarjeta
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      card.style.setProperty("--mouse-x", `${x}px`);
      card.style.setProperty("--mouse-y", `${y}px`);
    });
  });
</script>

<script>
  import emailjs from "@emailjs/browser";

  const contactForm = document.getElementById(
    "contact-form",
  ) as HTMLFormElement;

  contactForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    const serviceID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
    const templateID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
    const publicKey = import.meta.env.PUBLIC_EMAILJS_KEY;

    const btn = contactForm.querySelector("button");
    if (btn) btn.innerText = "Enviando...";

    try {
      await emailjs.sendForm(serviceID, templateID, contactForm, publicKey);

      alert("¡Mensaje enviado con éxito!");
      contactForm.reset();
    } catch (error) {
      console.error("Error al enviar:", error);
      alert("Ocurrió un error. Intenta de nuevo.");
    } finally {
      if (btn) btn.innerText = "Enviar";
    }
  });
</script>

<style>
  .parent {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(5, 1fr);
    grid-column-gap: 12px;
    grid-row-gap: 12px;
    padding: 0 1rem;
  }

  @media (max-width: 1024px) {
    .parent {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto;
    }

    .div1 {
      grid-area: 1 / 1 / 2 / 5 !important;
    }

    .div2 {
      grid-area: 2 / 1 / 3 / 5 !important;
    }

    .div3 {
      grid-area: 3 / 1 / 4 / 5 !important;
    }

    .div4 {
      grid-area: 4 / 1 / 5 / 5 !important;
    }
  }

  @media (max-width: 640px) {
    .parent {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 0 0.5rem;
    }

    .div1,
    .div2,
    .div3,
    .div4 {
      grid-area: auto !important;
    }
  }

  .card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
    padding: 1.5rem;
    transition: all 0.2s ease-in-out;
    backdrop-filter: blur(10px);
  }

  @media (max-width: 640px) {
    .card {
      padding: 1rem;
    }
  }

  .card:hover {
    transform: scale(1.01);
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(3px);
    border-color: rgba(7, 249, 162, 0.2);
  }

  .div1 {
    grid-area: 1 / 2 / 3 / 5;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }

  .div2 {
    grid-area: 3 / 2 / 5 / 3;
    display: flex;
    flex-direction: column;
  }

  .div3 {
    grid-area: 3 / 3 / 5 / 5;
    display: flex;
    flex-direction: column;
  }

  .div4 {
    grid-area: 5 / 2 / 6 / 5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 640px) {
    h2 {
      font-size: 1.25rem;
    }
  }

  h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 640px) {
    h3 {
      font-size: 1rem;
    }
  }

  input,
  textarea {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    border-radius: 0.5rem;
    padding: 0.20rem 0.65rem;
    margin-bottom: 0.5rem;
    outline: none;
    transition: all 0.2s ease;
  }

  input:focus,
  textarea:focus {
    border-color: #07f9a2;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
  }

  .button {
    /* in scss with just one variable i can change opacity with rgba(variable, opacity) but in css it's not possible so i have used three seperate variables */
    /* with hue-rotate color can be changed */
    --main-color: #07f9a2;
    --main-bg-color: rgba(46, 213, 116, 0.36);
    --pattern-color: rgba(46, 213, 116, 0.073);

    /* change this rotation value */
    filter: hue-rotate(0deg);

    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5rem;
    background:
      radial-gradient(circle, var(--main-bg-color) 0%, rgba(0, 0, 0, 0) 95%),
      linear-gradient(var(--pattern-color) 1px, transparent 1px),
      linear-gradient(to right, var(--pattern-color) 1px, transparent 1px);
    background-size:
      cover,
      15px 15px,
      15px 15px;
    background-position:
      center center,
      center center,
      center center;
    border-image: radial-gradient(
        circle,
        var(--main-color) 0%,
        rgba(0, 0, 0, 0) 100%
      )
      1;
    border-width: 1px 0 1px 0;
    color: var(--main-color);
    padding: 1rem 3rem;
    font-weight: 700;
    font-size: 1.5rem;
    transition: background-size 0.2s ease-in-out;
  }

  @media (max-width: 768px) {
    .button {
      padding: 0.75rem 2rem;
      font-size: 1.25rem;
      letter-spacing: 0.3rem;
    }
  }

  @media (max-width: 640px) {
    .button {
      padding: 0.75rem 1.5rem;
      font-size: 1rem;
      letter-spacing: 0.2rem;
    }
  }

  .button:hover {
    background-size:
      cover,
      10px 10px,
      10px 10px;
  }
  .button:active {
    filter: hue-rotate(250deg);
  }
</style>
