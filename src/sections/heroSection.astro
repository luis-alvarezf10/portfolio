---
import { socialLinks } from '../constants/socialLinks.ts'
import Badge from '../components/badges/Badge.astro';
---

<main
  id="home"
  class="min-h-[100dvh] flex flex-col items-start justify-center gap-6 md:gap-10 w-[80%] md:w-[80%] lg:w-[60%] mx-auto py-4 relative"
>
  <div
    class="flex flex-col-reverse md:flex-row items-start md:items-center gap-4 justify-between w-full"
  >
    <div>
      <!-- <img src={profile.src} alt="foto Luis Alvarez" class="w-16 h-16 rounded-full object-cover aspect-square"> -->
      <h1 class="text-3xl md:text-2xl lg:text-5xl font-bold">
        Hola! Soy Luis Álvarez
      </h1>
    </div>
    <img
      src="https://media.giphy.com/media/hvRJCLFzcasrR4ia7z/giphy.gif"
      width="35"
      class="hidden lg:inline"
    />
    <Badge variant="green">
      Disponible
    </Badge>
  </div>
  <p class="text-xl md:text-lg lg:text-xl">
    Estudiante de <span class="text-[#07f9a2] italic"
      >ingenería de sistemas</span
    >, apasionado en el desarrollo software.
  </p>
  <div
    class="flex flex-col md:flex-row justify-center md:justify-between items-start md:items-center gap-5 md:w-full"
  >
    <ul class="flex items-center gap-4">
      {
        socialLinks.map((link) => (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 hover:scale-110 transition bg-white/5 border border-white/10 p-2 rounded-xl hover:!text-[#07f9a2]"
            >
              <i class={`${link.icon} text-2xl`} />
              <span class="hidden lg:inline">{link.name}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <button
      class="button-hover bg-[#07f9a2] py-2 px-10 flex items-center gap-5 text-[#030b13] font-bold cursor-pointer rounded-xl w-full md:w-auto justify-center relative overflow-hidden"
    >
      <span class="relative z-0">Descargar CV</span>
      <i class="hn hn-download-solid relative"></i>
    </button>
  </div>
  <div class="flex-shrink-0 w-full flex justify-center items-center mt-4">
    <a href="#about" class="text-center flex flex-col items-center gap-2">
      <span>Acerca de mi</span>
      <i class="hn hn-arrow-down-solid animate-bounceY"></i>
    </a>
  </div>
</main>
