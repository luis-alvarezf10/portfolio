---
import { socialLinks } from "../constants/socialLinks";

const stats = [
  { label: "years_studying",    value: 4,   suffix: "+" },
  { label: "github_projects",   value: 18,  suffix: "+" },
  { label: "technologies",      value: 12,  suffix: "+" },
  { label: "commits",           value: 150, suffix: "+" },
];
---

<main
  id="home"
  class="relative min-h-[100dvh] flex flex-col items-center justify-center w-[92%] md:w-[88%] lg:w-[72%] mx-auto pt-24 pb-10"
>
  <!-- Status strip -->
  <div class="mb-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-[color:var(--terminal-muted)]">
    <span class="inline-flex items-center gap-2">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-[color:var(--terminal-green)] shadow-[0_0_8px_rgba(7,249,162,0.8)]"></span>
      <span class="text-[color:var(--terminal-green)]">available</span>
      <span class="text-[color:var(--terminal-comment)]">// open to work</span>
    </span>
    <span class="text-[color:var(--terminal-comment)]">│</span>
    <span>location: <span class="text-[color:var(--terminal-text)]">VE</span></span>
    <span class="text-[color:var(--terminal-comment)]">│</span>
    <span>uptime: <span class="text-[color:var(--terminal-text)]">4y+</span></span>
  </div>

  <!-- Terminal window -->
  <div class="tw-window w-full animate-fade-up">
    <!-- Title bar -->
    <div class="tw-titlebar">
      <span class="tw-dot tw-dot-red"></span>
      <span class="tw-dot tw-dot-yellow"></span>
      <span class="tw-dot tw-dot-green"></span>
      <div class="flex-1 text-center select-none">
        <span class="text-[color:var(--terminal-comment)]">—</span>
        <span class="text-[color:var(--terminal-muted)]">luis@portfolio</span>
        <span class="text-[color:var(--terminal-comment)]">:</span>
        <span class="text-[color:var(--terminal-green)]">~</span>
        <span class="text-[color:var(--terminal-comment)]"> — zsh — 80×24</span>
      </div>
      <span class="text-[10px] text-[color:var(--terminal-comment)] hidden sm:inline">v2.0.0</span>
    </div>

    <!-- Body -->
    <div class="px-5 md:px-8 py-6 md:py-8 text-sm md:text-[15px] leading-relaxed">
      <!-- whoami -->
      <div class="flex items-start gap-2">
        <span class="text-[color:var(--terminal-green)] font-bold select-none">$</span>
        <span>whoami</span>
      </div>
      <h1 class="mt-2 pl-4 font-sans text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight text-balance">
        Luis <span class="text-[color:var(--terminal-green)]">Álvarez</span> Franceschi
      </h1>
      <p class="pl-4 mt-1 text-[color:var(--terminal-muted)]">
        <span class="text-[color:var(--terminal-comment)]">// </span>
        Fullstack &amp; Mobile Developer — Ingeniería de Sistemas
      </p>

      <div class="my-5 glow-underline"></div>

      <!-- role / passions -->
      <div class="flex items-start gap-2">
        <span class="text-[color:var(--terminal-green)] font-bold select-none">$</span>
        <span>./run --passions</span>
      </div>
      <p class="pl-4 mt-2 text-[color:var(--terminal-text)]">
        <span class="text-[color:var(--terminal-comment)]">&gt;</span>
        <span
          id="typewriter"
          class="text-[color:var(--terminal-green)] font-semibold"
        ></span>
      </p>

      <div class="my-5 glow-underline"></div>

      <!-- stats -->
      <div class="flex items-start gap-2">
        <span class="text-[color:var(--terminal-green)] font-bold select-none">$</span>
        <span>cat stats.json</span>
      </div>
      <div class="pl-4 mt-3 grid grid-cols-2 sm:grid-cols-4 gap-3 md:gap-4">
        {
          stats.map((stat) => (
            <div class="stat-card rounded-md border border-[color:var(--terminal-border)] bg-black/20 p-3 md:p-4">
              <div class="flex items-baseline gap-0.5">
                <span class="text-2xl md:text-3xl font-bold text-[color:var(--terminal-green)] counter" data-target={stat.value}>0</span>
                <span class="text-xl font-bold text-[color:var(--terminal-green)]">{stat.suffix}</span>
              </div>
              <div class="mt-1 text-[10px] md:text-[11px] uppercase tracking-[0.15em] text-[color:var(--terminal-muted)]">
                {stat.label}
              </div>
            </div>
          ))
        }
      </div>

      <div class="my-6 glow-underline"></div>

      <!-- actions -->
      <div class="flex items-start gap-2">
        <span class="text-[color:var(--terminal-green)] font-bold select-none">$</span>
        <span>ls ./actions</span>
      </div>
      <div class="pl-4 mt-3 flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
        <a
          href="https://drive.google.com/drive/folders/1iy9-dpCE63PiNxx4-xOQoj8nf2VvCCsd?usp=drive_link"
          target="_blank"
          rel="noopener noreferrer"
          class="cmd-btn cmd-btn-primary justify-center"
        >
          <span>./download_cv.sh</span>
          <i class="hn hn-download-solid"></i>
        </a>
        <a href="#contact" class="cmd-btn justify-center">
          <span>./contact.sh</span>
          <span class="blink">_</span>
        </a>
        <div class="hidden md:block flex-1"></div>
        <ul class="flex items-center gap-2">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={link.name}
                  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[color:var(--terminal-border-strong)] text-[color:var(--terminal-muted)] transition-all hover:border-[color:var(--terminal-green-dim)] hover:text-[color:var(--terminal-green)] hover:bg-[color:var(--terminal-green-faint)]"
                >
                  <i class={link.icon}></i>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- trailing cursor -->
      <div class="mt-6 flex items-center gap-2 text-[color:var(--terminal-green)]">
        <span class="font-bold select-none">$</span>
        <span class="blink font-bold">_</span>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <a
    href="#about"
    class="mt-8 inline-flex flex-col items-center gap-1 text-xs text-[color:var(--terminal-muted)] transition-colors hover:text-[color:var(--terminal-green)]"
  >
    <span class="text-[color:var(--terminal-comment)]">// scroll para continuar</span>
    <i class="hn hn-arrow-down-solid animate-bounce"></i>
  </a>
</main>

<script>
  // @ts-ignore
  import Typed from "typed.js";

  const setupTyped = () => {
    const target = document.querySelector("#typewriter");
    if (!target) return;
    // @ts-ignore
    new Typed("#typewriter", {
      strings: [
        "web_development.init()",
        "mobile_apps.build()",
        "ai_automation.run()",
        "fullstack.ship()",
      ],
      typeSpeed: 55,
      backSpeed: 35,
      backDelay: 1800,
      loop: true,
      cursorChar: "_",
    });
  };

  setupTyped();
  document.addEventListener("astro:after-swap", setupTyped);
</script>

<script is:inline>
  // Counter animation when in view
  const startCounter = (el) => {
    const target = parseInt(el.getAttribute("data-target"));
    const duration = 1500;
    const step = target / (duration / 16);
    let current = 0;
    const tick = () => {
      current += step;
      if (current < target) {
        el.innerText = Math.floor(current).toString();
        requestAnimationFrame(tick);
      } else {
        el.innerText = target.toString();
      }
    };
    tick();
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const counter = entry.target.querySelector(".counter");
          if (counter) startCounter(counter);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll(".stat-card").forEach((el) => observer.observe(el));
</script>

<style is:global>
  .typed-cursor {
    color: var(--terminal-green);
    font-weight: 700;
    text-shadow: 0 0 8px rgba(7, 249, 162, 0.6);
  }
</style>
