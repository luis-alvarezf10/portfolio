---
import { workExperience } from "../constants/workExperience";
---

<section class="grid w-[80%] md:w-[80%] lg:w-[60%] mx-auto gap-10 py-20">
  <h2 class="font-bold text-4xl">Experiencia laboral</h2>
  
  <ol class="flex flex-col md:flex-row items-start gap-8 md:gap-4">
    {
      workExperience.map((job) => (
        <li class="relative mb-6 sm:mb-0 md:w-1/3">
          <div class="flex items-center gap-5">
            <div class="bg-[#07f9a2]/5 w-14 h-14 rounded-xl flex items-center justify-center text-[#07f9a2] border border-[#07f9a2]/20 text-2xl shrink-0">
              <i class={job.icon} />
            </div>
            <h3 class="text-lg md:text-sm lg:text-xl font-semibold text-[#07f9a2]">
              {job.company}
            </h3>
          </div>
          
          <div class="mt-3 md:pe-8">
            <time class="text-xs font-medium text-gray-500">
              {job.date}
            </time>
            <p class="text-base md:text-sm lg:text-md mt-2 text-gray-400">
              {job.description}
            </p>
          </div>
        </li>
      ))
    }
  </ol>
</section>