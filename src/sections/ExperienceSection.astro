---
import { workExperience } from "../constants/workExperience";

// Generate a deterministic short hash from a string (for git-log look)
function hashShort(str: string) {
  let h = 5381;
  for (let i = 0; i < str.length; i++) {
    h = ((h << 5) + h) + str.charCodeAt(i);
    h = h >>> 0;
  }
  return h.toString(16).padStart(7, "0").slice(0, 7);
}

const commits = workExperience.map((job, i) => ({
  ...job,
  hash: hashShort(job.company + job.date + i),
  branch: i === 0 ? "main" : i === 1 ? "feature/desktop-apps" : "feature/banking-api",
  isHead: i === 0,
}));
---

<div class="w-[92%] md:w-[88%] lg:w-[72%] mx-auto">
  <!-- Header -->
  <header class="mb-8 flex items-end justify-between flex-wrap gap-4">
    <div>
      <p class="text-xs text-[color:var(--terminal-muted)] prompt-line">git log --oneline --experience</p>
      <h2 class="font-sans text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mt-1 text-balance">
        <span class="text-[color:var(--terminal-comment)]">{"//"}</span> experience
      </h2>
    </div>
    <span class="hidden md:inline text-xs text-[color:var(--terminal-comment)]">
      {commits.length} commits · main
    </span>
  </header>

  <!-- Terminal log -->
  <div class="tw-window">
    <div class="tw-titlebar">
      <span class="tw-dot tw-dot-red"></span>
      <span class="tw-dot tw-dot-yellow"></span>
      <span class="tw-dot tw-dot-green"></span>
      <div class="flex-1 text-center text-[color:var(--terminal-muted)]">
        <span class="text-[color:var(--terminal-comment)]">—</span>
        <span>git log</span>
        <span class="text-[color:var(--terminal-comment)]"> — experience/main</span>
      </div>
    </div>

    <div class="p-5 md:p-8 text-sm md:text-[15px]">
      <ol class="space-y-6">
        {
          commits.map((c, i) => (
            <li class="group relative grid grid-cols-[auto_1fr] gap-3 md:gap-4">
              <!-- graph column -->
              <div class="flex flex-col items-center pt-1">
                <span class="text-[color:var(--terminal-green)] text-base leading-none">●</span>
                {i < commits.length - 1 && (
                  <span class="mt-1 w-px flex-1 bg-gradient-to-b from-[color:var(--terminal-green-dim)] to-transparent"></span>
                )}
              </div>

              <!-- content -->
              <div class="pb-2">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="ansi-yellow font-semibold">commit {c.hash}</span>
                  {c.isHead && (
                    <span class="inline-flex items-center gap-1 rounded-sm bg-[color:var(--terminal-green-faint)] px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-[color:var(--terminal-green)] border border-[color:var(--terminal-green-dim)]">
                      HEAD → {c.branch}
                    </span>
                  )}
                  {!c.isHead && (
                    <span class="inline-flex items-center gap-1 rounded-sm bg-black/20 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-[color:var(--terminal-muted)] border border-[color:var(--terminal-border)]">
                      {c.branch}
                    </span>
                  )}
                </div>

                <dl class="mt-2 grid grid-cols-[auto_1fr] gap-x-3 gap-y-0.5 text-sm">
                  <dt class="ansi-muted">Author:</dt>
                  <dd class="flex items-center gap-2">
                    <i class={`${c.icon} text-[color:var(--terminal-green)]`}></i>
                    <span class="text-[color:var(--terminal-text)] font-semibold">
                      {c.company}
                    </span>
                    <span class="ansi-comment">&lt;dev@{c.company.toLowerCase().replace(/\s+/g, "")}&gt;</span>
                  </dd>
                  <dt class="ansi-muted">Date:</dt>
                  <dd class="text-[color:var(--terminal-text)]">{c.date}</dd>
                </dl>

                <p class="mt-3 pl-4 text-[color:var(--terminal-muted)] leading-relaxed border-l border-[color:var(--terminal-border)] group-hover:border-[color:var(--terminal-green-dim)] transition-colors">
                  {c.description}
                </p>
              </div>
            </li>
          ))
        }
      </ol>

      <div class="mt-8 flex items-center gap-2 text-[color:var(--terminal-green)]">
        <span class="font-bold select-none">$</span>
        <span class="blink font-bold">_</span>
      </div>
    </div>
  </div>
</div>
