---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../sections/HeroSection.astro';
import AboutSection from '../sections/AboutSection.astro';
import Projects from '../components/Projects.astro';
import ContactSection from '../sections/ContactSection.astro';
import NavigationButtons from '../components/NavigationButtons.astro';
---

<Layout
  title="Luis Alvarez - Desarrollador Fullstack & Mobile"
  description="Desarrollador de software especializado en aplicaciones multiplataforma y web. Transforma tus ideas en productos digitales escalables con Luis Álvarez."
>
  <NavigationButtons />

  <!-- Fondo: grid de terminal + vignette -->
  <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 terminal-grid"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(7,249,162,0.08),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_100%,rgba(7,249,162,0.04),transparent_70%)]"></div>
  </div>

  <HeroSection />
  <AboutSection />
  <Projects />
  <ContactSection />
</Layout>
