---
import Layout from '../layouts/Layout.astro';
import profile from '../assets/foto-carnet.jpg'
import HeroSection from '../sections/HeroSection.astro';
import AboutSection from '../sections/AboutSection.astro'
import Projects from '../components/Projects.astro'
import ContactSection from '../components/ContactSection.astro'
import WorkExperience from '../sections/ExperienceSection.astro';
import NavigationButtons from '../components/NavigationButtons.astro';
---

<Layout title="Luis Alvarez - desarollador software"
description="Contrata a Luis Álvarez para gestionar tu ideas. Desarrollo de aplicaciones multiplataforma y páginas web. ">
  <NavigationButtons/>
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <div class="gradient-blob gradient-blob-1 absolute h-[400px] w-[400px] rounded-full bg-[radial-gradient(circle_farthest-side,rgba(7,249,162,0.15),rgba(255,255,255,0))]"></div>
    <div class="gradient-blob gradient-blob-2 absolute h-[400px] w-[400px] rounded-full bg-[radial-gradient(circle_farthest-side,rgba(7,249,162,0.15),rgba(255,255,255,0))]"></div>
    <div class="gradient-blob gradient-blob-3 absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]"></div>
  </div>
  <HeroSection />
	<AboutSection />
  <!-- <Projects /> -->
  <ContactSection />
</Layout>

<style>
html {
  scroll-behavior: smooth;
}

body {
  overflow-x: hidden;
}

@keyframes float1 {
  0%, 100% {
    transform: translate(-50%, 0%) scale(1);
  }
  33% {
    transform: translate(-30%, 20%) scale(1.1);
  }
  66% {
    transform: translate(-70%, -10%) scale(0.9);
  }
}

@keyframes float2 {
  0%, 100% {
    transform: translate(50%, 0%) scale(1);
  }
  33% {
    transform: translate(70%, -15%) scale(0.9);
  }
  66% {
    transform: translate(30%, 25%) scale(1.1);
  }
}

@keyframes float3 {
  0%, 100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.5;
  }
}

.gradient-blob {
  filter: blur(60px);
}

.gradient-blob-1 {
  top: 10%;
  left: 0;
  animation: float1 20s ease-in-out infinite;
}

.gradient-blob-2 {
  top: 40%;
  right: 0;
  animation: float2 25s ease-in-out infinite;
}

.gradient-blob-3 {
  animation: float3 15s ease-in-out infinite;
}

</style>
